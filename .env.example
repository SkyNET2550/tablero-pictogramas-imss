# GENERAL
APP_ENV=development
APP_NAME=PictogramasInstitucionalesCAA
APP_NAME_PLAN=Pictogramas_CAA_IMSS
DEFAULT_LANGUAGE=es
DEFAULT_OUTPUT_FORMAT=html
DEFAULT_PROVIDER=ARASAAC
LOCAL_STORAGE_PATH=assets/pictograms
OUTPUT_PATH=outputs

# ARASAAC
ARASAAC_BASE_URL=https://api.arasaac.org/api

# OPENSYMBOLS
OPENSYMBOLS_BASE_URL=https://www.opensymbols.org
OPENSYMBOLS_API_TOKEN=

# GLOBAL SYMBOLS
GLOBAL_SYMBOLS_BASE_URL=https://globalsymbols.com/api/v2
GLOBAL_SYMBOLS_API_KEY=
GLOBAL_SYMBOLS_AUTH_MODE=x-api-key
GLOBAL_SYMBOLS_DEFAULT_LANGUAGE=es
GLOBAL_SYMBOLS_TIMEOUT_MS=10000
OPENSYMBOLS_SECRET=
OPENSYMBOLS_TOKEN=
PROVIDER_TIMEOUT_MS=8000
CHECK_PROVIDERS_ON_STARTUP=true
ALLOW_UNKNOWN_PROVIDERS_IN_SEARCH=false

# SYMBOTALK
SYMBOTALK_API_KEY=
